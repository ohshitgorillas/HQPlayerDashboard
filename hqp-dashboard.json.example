{
  "title": "opal \u2014 HQPlayer Performance",
  "uid": "opal-hqp-perf",
  "schemaVersion": 39,
  "version": 4,
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timezone": "browser",
  "tags": [
    "hqplayer",
    "opal",
    "pcm",
    "audio"
  ],
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "HQPlayer Status",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Now Playing",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 8,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "name",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "noValue": "STOPPED / PAUSED"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "hqplayer_track_info",
          "legendFormat": "{{artist}} \u2014 {{song}}  \u00b7  {{album}} ({{date}})",
          "refId": "A",
          "interval": "",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Process Speed  (\u00d7realtime)",
      "gridPos": {
        "x": 18,
        "y": 1,
        "w": 3,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 5,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 1.3
              },
              {
                "color": "yellow",
                "value": 2.5
              },
              {
                "color": "green",
                "value": 4.0
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "hqplayer_process_speed",
          "legendFormat": "speed",
          "refId": "A",
          "interval": ""
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Output",
      "gridPos": {
        "x": 10,
        "y": 1,
        "w": 2,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "name",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "hqplayer_info",
          "legendFormat": "{{output_fmt}}",
          "refId": "A",
          "interval": "",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Source",
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 2,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "name",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "noValue": "\u2014"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "hqplayer_track_info",
          "legendFormat": "{{source_fmt}}",
          "refId": "A",
          "interval": "",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Format \u00b7 Filter \u00b7 Shaper",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 4,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "name",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "hqplayer_info",
          "legendFormat": "{{mode}} \u00b7 {{filter}} \u00b7 {{shaper}}",
          "refId": "A",
          "interval": "",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "Output Buffer Fill",
      "gridPos": {
        "x": 21,
        "y": 1,
        "w": 3,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 85
              },
              {
                "color": "yellow",
                "value": 90
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "hqplayer_output_fill_ratio * 100",
          "legendFormat": "",
          "refId": "A",
          "interval": ""
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Volume",
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 2,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dB",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "hqplayer_volume_db",
          "legendFormat": "",
          "refId": "A",
          "interval": ""
        }
      ]
    },
    {
      "id": 9,
      "type": "row",
      "title": "CPU",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Per-Core Actual Frequency",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 7,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "hertz",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 0,
            "spanNulls": true,
            "gradientMode": "none",
            "showPoints": "never"
          },
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "B"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash"
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 2
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "rgba(200,200,200,0.5)"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "avg_over_time(node_cpu_scaling_frequency_hertz{instance=\"opal\"}[30s])",
          "legendFormat": "cpu{{cpu}}",
          "refId": "A",
          "interval": ""
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max(node_cpu_frequency_max_hertz{instance=\"opal\"})",
          "legendFormat": "max turbo",
          "refId": "B",
          "interval": ""
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "CPU Temperatures",
      "gridPos": {
        "x": 7,
        "y": 7,
        "w": 7,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "spanNulls": true,
            "gradientMode": "none",
            "showPoints": "never"
          },
          "min": 20
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max(node_hwmon_temp_celsius{instance=\"opal\",chip=\"platform_coretemp_0\"})",
          "legendFormat": "max",
          "refId": "A",
          "interval": ""
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "avg(node_hwmon_temp_celsius{instance=\"opal\",chip=\"platform_coretemp_0\"})",
          "legendFormat": "avg",
          "refId": "B",
          "interval": ""
        }
      ]
    },
    {
      "id": 12,
      "type": "heatmap",
      "title": "Per-Core Utilization",
      "gridPos": {
        "x": 14,
        "y": 7,
        "w": 7,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {
          "scheme": "RdYlGn",
          "reverse": false,
          "min": 0,
          "max": 1,
          "mode": "scheme",
          "scale": "linear",
          "steps": 64
        },
        "filterValues": {
          "le": 1e-09
        },
        "legend": {
          "show": false
        },
        "rowsFrame": {
          "layout": "auto"
        },
        "tooltip": {
          "mode": "single",
          "showColorScale": false
        },
        "yAxis": {
          "axisLabel": "CPU",
          "reverse": false,
          "unit": "short"
        }
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "custom": {
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "scaleDistribution": {
              "type": "linear"
            }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "1 - rate(node_cpu_seconds_total{instance=\"opal\",mode=\"idle\"}[30s])",
          "legendFormat": "{{cpu}}",
          "refId": "A",
          "interval": ""
        }
      ]
    },
    {
      "id": 13,
      "type": "bargauge",
      "title": "Busiest",
      "gridPos": {
        "x": 21,
        "y": 7,
        "w": 3,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "displayMode": "basic",
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 0.85
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "topk(2, 1 - irate(node_cpu_seconds_total{instance=\"opal\",mode=\"idle\"}[30s]))",
          "legendFormat": "cpu{{cpu}}",
          "refId": "A",
          "interval": "",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 14,
      "type": "row",
      "title": "GPU \u2014 RTX 3060 Ti",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "SM & Memory Controller Utilization",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": true,
            "gradientMode": "none",
            "showPoints": "never"
          },
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "DCGM_FI_DEV_GPU_UTIL",
          "legendFormat": "SM Util %",
          "refId": "A",
          "interval": ""
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "DCGM_FI_DEV_MEM_COPY_UTIL",
          "legendFormat": "Mem Ctrl Util %",
          "refId": "B",
          "interval": ""
        }
      ]
    },
    {
      "id": 16,
      "type": "gauge",
      "title": "VRAM Used",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "min": 0,
          "max": 8192,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 6000
              },
              {
                "color": "red",
                "value": 7500
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "DCGM_FI_DEV_FB_USED",
          "legendFormat": "",
          "refId": "A",
          "interval": ""
        }
      ]
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "VRAM Over Time",
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": true,
            "gradientMode": "none",
            "showPoints": "never"
          },
          "min": 0,
          "max": 8192
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "DCGM_FI_DEV_FB_USED",
          "legendFormat": "VRAM MiB",
          "refId": "A",
          "interval": ""
        }
      ]
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "GPU Temp & Power",
      "gridPos": {
        "x": 16,
        "y": 16,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "spanNulls": true,
            "gradientMode": "none",
            "showPoints": "never"
          },
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "DCGM_FI_DEV_GPU_TEMP",
          "legendFormat": "Temp \u00b0C",
          "refId": "A",
          "interval": ""
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "DCGM_FI_DEV_POWER_USAGE",
          "legendFormat": "Power W",
          "refId": "B",
          "interval": ""
        }
      ]
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "SM Clock & Mem Clock",
      "gridPos": {
        "x": 16,
        "y": 20,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "hertz",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 0,
            "spanNulls": true,
            "gradientMode": "none",
            "showPoints": "never"
          },
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
