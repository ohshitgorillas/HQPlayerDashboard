          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "(irate(DRAM_Reads{aggregate=\"system\",source=\"uncore\"}[2m]) + irate(DRAM_Writes{aggregate=\"system\",source=\"uncore\"}[2m])) / 102.4e9 * 100",
          "legendFormat": "",
          "refId": "A",
          "interval": ""
        }
      ]
