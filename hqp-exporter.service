[Unit]
Description=HQPlayer Status exporter for Prometheus
After=network.target hqplayerd.service
Wants=hqplayerd.service

[Service]
Type=simple
User=nobody
Group=nogroup
ExecStart=/srv/hqpexporter/venv/bin/python \
    /srv/hqpexporter/hqp_exporter.py \
    --port 9744 --interval 2
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
